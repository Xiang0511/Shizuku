@model Shizuku.Models.TTicketsCustomer

@{
    ViewData["Title"] = "Edit";
}

<h1>編輯</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="FId" />
            <div class="form-group">
                <label asp-for="FMemberId" class="control-label"></label>
                <input asp-for="FMemberId" class="form-control" />
                <span asp-validation-for="FMemberId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FOrderId" class="control-label"></label>
                <input asp-for="FOrderId" class="form-control" />
                <span asp-validation-for="FOrderId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FCategoryId" class="control-label"></label>
                <select asp-for="FCategoryId" class="form-control"
                        asp-items="@(IEnumerable<SelectListItem>)ViewBag.CategoryOptions">
                    <option value="">-- 請選擇問題分類 --</option>
                </select>
                <span asp-validation-for="FCategoryId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FSubject" class="control-label"></label>
                <input asp-for="FSubject" class="form-control" />
                <span asp-validation-for="FSubject" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FStatus" class="control-label"></label>
                <select asp-for="FStatus" class="form-control">
                    <option value="待處理">待處理</option>
                    <option value="處理中">處理中</option>
                    <option value="已結案">已結案</option>
                    <option value="不予處理">不予處理</option>
                </select>
                <span asp-validation-for="FStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FPriority" class="control-label"></label>
                <input asp-for="FPriority" class="form-control" />
                <span asp-validation-for="FPriority" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FAssignedAgentId" class="control-label"></label>
                <input asp-for="FAssignedAgentId" class="form-control" />
                <span asp-validation-for="FAssignedAgentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FCreatedAt" class="control-label"></label>
                <input asp-for="FCreatedAt" class="form-control" />
                <span asp-validation-for="FCreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FUpdatedAt" class="control-label"></label>
                <input asp-for="FUpdatedAt" class="form-control" />
                <span asp-validation-for="FUpdatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FClosedAt" class="control-label"></label>
                <input asp-for="FClosedAt" class="form-control" />
                <span asp-validation-for="FClosedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="存檔" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="List">返回列表</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

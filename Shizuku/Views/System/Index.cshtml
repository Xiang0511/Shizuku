@model IEnumerable<Shizuku.ViewModels.LogViewModel>

@{
    ViewData["Title"] = "系統日誌管理";
    var currentLevel = ViewBag.CurrentLevel as string;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-terminal"></i> 系統日誌 (System Logs)</h2>
        
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0">顯示等級：</label>
            <select class="form-select w-auto" id="levelFilter" onchange="filterLogs()">
                <option value="">-- 全部顯示 --</option>
                <option value="Information" selected="@(currentLevel == "Information")">Information</option>
                <option value="Warning" selected="@(currentLevel == "Warning")">Warning</option>
                <option value="Error" selected="@(currentLevel == "Error")">Error</option>
                <option value="Fatal" selected="@(currentLevel == "Fatal")">Fatal</option>
            </select>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">時間</th>
                        <th>等級</th>
                        <th>訊息內容</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">@item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                @if (item.Level == "Error" || item.Level == "Fatal")
                                {
                                    <span class="badge rounded-pill bg-danger">@item.Level</span>
                                }
                                else if (item.Level == "Warning")
                                {
                                    <span class="badge rounded-pill bg-warning text-dark">@item.Level</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-info text-white">@item.Level</span>
                                }
                            </td>
                            <td class="text-truncate" style="max-width: 500px;" title="@item.Message">
                                @item.Message
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary" onclick="showLogDetail('@item.Id')">
                                    <i class="fas fa-eye"></i> 查看
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 簡單的跳轉邏輯
        function filterLogs() {
            var selectedLevel = document.getElementById("levelFilter").value;
            window.location.href = "/System/Index?level=" + selectedLevel;
        }
    </script>
}